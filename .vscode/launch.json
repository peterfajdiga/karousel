{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Test",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/run-ts-tmp.js",
            "args": ["${input:testsPattern}"],
            "preLaunchTask": "Build tests"
        }
    ],
    "inputs": [
        {
            "id": "testsPattern",
            "type": "promptString",
            "description": "Name pattern of tests to run"
        }
    ]
}
